  w - v = Vec([[0, 1, 0], [1, 3, 0], [5, 7, 0]])
  -v = Vec([[-1, 2, 0], [-1, 3, 0], [-1, 7, 0]])
  v * 2 = Vec([[1, 1, 0], [2, 3, 0], [2, 7, 0]])
  v · w = [1049, 1764, 0]  (= 1049/1764)

